  "object_constraints": [
    {"constraint": "account_owner は剥奪不可（owner 移譲が先に必要）", "enforce": "API + DB trigger"},
    {"constraint": "self-permission strip は他 admin が居なければ block", "enforce": "API guard"},
    {"constraint": "workspace 内に admin が 0 になることを禁止", "enforce": "API + UI 警告"},
    {"constraint": "monitor は edit / delete / invite_member 不可", "enforce": "RLS + custom_permissions 評価"},
    {"constraint": "client は visible_tabs に含まれないタブの API エンドポイント全 403", "enforce": "RLS + API middleware"},
    {"constraint": "viewer に edit_* 権限を override で付与した場合は警告（一貫性チェック）", "enforce": "UI 警告"},
    {"constraint": "monitor + admin の両方を 1 user に付与可（OR 評価）", "enforce": "custom_permissions JSONB OR-merge"}
  ],
  "rls_design_summary": "全テーブルに workspace_id NOT NULL + RLS で workspace_members 経由の所属チェック + custom_permissions JSONB でロール default + 個別 override を OR 評価"
