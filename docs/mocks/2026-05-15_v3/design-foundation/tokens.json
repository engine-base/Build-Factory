  "typography": {
    "fonts": {
      "sans": "Noto Sans JP, Inter, system-ui, sans-serif",
      "mono": "JetBrains Mono, ui-monospace, monospace"
    },
    "scale": {
      "h1":      { "size": "24px", "tailwind": "text-2xl", "line-height": "1.4", "weight": 700 },
      "h2":      { "size": "18px", "tailwind": "text-lg",  "line-height": "1.45", "weight": 700 },
      "h3":      { "size": "16px", "tailwind": "text-base","line-height": "1.5", "weight": 600 },
      "h4":      { "size": "14px", "tailwind": "text-sm",  "line-height": "1.5", "weight": 600 },
      "body":    { "size": "14px", "tailwind": "text-sm",  "line-height": "1.7", "weight": 400 },
      "caption": { "size": "13px", "tailwind": "text-[13px]", "line-height": "1.6", "weight": 400 },
      "label":   { "size": "12px", "tailwind": "text-xs",  "line-height": "1.5", "weight": 500 },
      "micro":   { "size": "11px", "tailwind": "text-[11px] uppercase tracking-wider", "line-height": "1.4", "weight": 700 },
      "code":    { "size": "13px", "tailwind": "text-[13px] mono", "line-height": "1.5", "weight": 400 },
      "kpi":     { "size": "28px", "tailwind": "text-[28px] font-bold mono tabular-nums", "line-height": "1.2", "weight": 700 }
    },
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "letter-spacing": { "body": "0", "micro": "0.05em" }
  },
  "spacing": {
    "grid": "4px",
    "scale": ["0", "1px", "4px", "8px", "12px", "16px", "20px", "24px", "32px", "40px"],
    "tailwind": ["", "border", "gap-1/p-1", "gap-2/p-2", "gap-3/p-3", "gap-4/p-4", "p-5", "space-y-6", "space-y-8", "space-y-10"],
    "sidebar-width": "240px",
    "container-max": "1400px",
    "page-padding": "24px",
    "card-padding": "20px"
  },
  "radius": {
    "modal": "12px",
    "card": "8px",
    "button": "6px",
    "input": "6px",
    "badge": "9999px",
    "avatar": "9999px"
  },
  "shadow": {
    "card-default": "none",
    "card-hover": "0 1px 2px rgba(0,0,0,0.04)",
    "popover":  "0 4px 12px rgba(0,0,0,0.10)",
    "modal":    "0 12px 32px rgba(0,0,0,0.12)"
  },
  "animation": {
    "transition-default": "150ms ease-in-out",
    "transition-modal": "200ms ease-out",
    "pulse-dot": "1.4s pulse infinite",
    "skeleton": "1.5s pulse infinite"
  },
  "breakpoints": {
    "xl": "1280px",
    "lg": "1024px",
    "md": "768px",
    "sm": "640px"
  },
  "icons": {
    "library": "lucide",
    "cdn": "https://unpkg.com/lucide@latest",
    "default-size": "w-4 h-4",
    "rule": "Lucide only. NO emoji. NO heroicons/material/react-icons (enforced by lint #1)"
  }
}
