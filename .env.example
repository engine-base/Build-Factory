# Build-Factory environment variables (template)
# Copy to .env and fill in production values

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# === Supabase ===
# ローカル: `supabase start` で表示される値をコピーすること
# 本番:    Supabase Dashboard > Project Settings > API から取得
# 注意:    実鍵は git にコミットしない (.env は .gitignore 済み)。
#          ANON は公開可、SERVICE は絶対秘匿。
SUPABASE_URL=REPLACE_WITH_SUPABASE_URL                        # 例: http://127.0.0.1:54321
SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY              # publishable / anon key
SUPABASE_SERVICE_KEY=REPLACE_WITH_SUPABASE_SERVICE_KEY        # secret / service-role key (秘匿)
SUPABASE_JWT_SECRET=REPLACE_WITH_SUPABASE_JWT_SECRET          # HS256 検証用 (>=32 chars)
SUPABASE_BUCKET=artifacts

# === Auth bypass for local dev (set to 0 in production) ===
BUILD_FACTORY_DEV_BYPASS_AUTH=1

# === LLM / AI ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

# === Optional integrations ===
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
