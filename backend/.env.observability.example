# ============================================================
# Observability + Orchestration スタック設定
# ============================================================
# .env にコピーして必要な値を設定してください

# === Phase 1: Langfuse (観測) ===
# self-host で立てた Langfuse の URL とキー
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# === Phase 2: Instructor (構造化抽出) ===
USE_INSTRUCTOR=1

# === Phase 3: LangGraph (オーケストレーション) ===
USE_LANGGRAPH=1

# === Phase 4: Mem0 (長期記憶) ===
USE_MEM0=0
# Mem0 が使う LLM (好みのモデルに変更可)
MEM0_LLM_MODEL=gpt-4o-mini
# Qdrant を使う場合 (デフォルトは Chroma ローカル)
USE_QDRANT=0
QDRANT_HOST=localhost
QDRANT_PORT=6333
