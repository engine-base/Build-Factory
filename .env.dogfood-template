# Phase 1 dogfood .env テンプレ
# 使い方:
#   cp .env.dogfood-template .env
#   nano .env  # ← 下記の [REPLACE_*] を全部書き換え
#   bash start-dogfood.sh

# ────────────────────────────────────────────────────────────
# Supabase
# ────────────────────────────────────────────────────────────
# 取得元: https://supabase.com/dashboard/project/[YOUR_PROJECT_REF]/settings/api

SUPABASE_URL=https://[REPLACE_PROJECT_REF].supabase.co

# 新名前 (Supabase 推奨命名)
# "Project API keys" セクション → "publishable" key (旧 anon_key)
SUPABASE_PUBLISHABLE_KEY=[REPLACE_WITH_SUPABASE_PUBLISHABLE_KEY]
# "Project API keys" セクション → "secret" key (旧 service_role_key)
SUPABASE_SECRET_KEY=[REPLACE_WITH_SUPABASE_SECRET_KEY]

# 旧名前 (backend/config.py が要求 / 同値で OK)
SUPABASE_ANON_KEY=[REPLACE_WITH_SAME_AS_PUBLISHABLE_KEY]
SUPABASE_SERVICE_KEY=[REPLACE_WITH_SAME_AS_SECRET_KEY]

# JWT Secret
# 取得元: 同じく Settings → API → "JWT Settings" セクション → "JWT Secret"
SUPABASE_JWT_SECRET=[REPLACE_WITH_JWT_SECRET]

# DB direct connection URL
# 取得元: Settings → Database → "Connection string" → "URI" タブ
# 注意: password 内の特殊文字 ! # @ は URL encode 必須:
#       ! → %21 / # → %23 / @ → %40 / $ → %24
DATABASE_URL=postgresql://postgres:[URL_ENCODED_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────
# AI provider
# ────────────────────────────────────────────────────────────
# 取得元: https://console.anthropic.com/settings/keys
#   → "Create Key" → name: "build-factory-dogfood" → 表示された値をコピー
ANTHROPIC_API_KEY=[REPLACE_WITH_ANTHROPIC_API_KEY]

# 任意 (使うなら) — 未設定でも backend 起動には影響なし
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ────────────────────────────────────────────────────────────
# Build-Factory settings (変更不要)
# ────────────────────────────────────────────────────────────
BF_ENV=development
DISABLE_BACKGROUND_WORKERS=1
